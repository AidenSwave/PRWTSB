{
  "name": "script-editor",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "npm run build:electron",
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "test": "node --test tests/*.test.mjs",
    "start": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@xyflow/react": "^12.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "concurrently": "^9.1.2",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.scripteditor.desktop",
    "productName": "Script Editor",
    "files": ["dist/**/*", "dist-electron/**/*", "package.json"],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" }
  }
}
